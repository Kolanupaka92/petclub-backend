# ─────────────────────────────────────────────────────────────
#  PETclub Backend — Environment Variables
#  Set all of these in Railway → petclub-backend → Variables
# ─────────────────────────────────────────────────────────────

PORT=5000
FRONTEND_URL=https://app.mypetclub.app

# ── Auth ───────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here

# ── Supabase ───────────────────────────────────────────────
# Get from: app.supabase.com → Your Project → Project Settings → API
SUPABASE_URL=https://zjrgbsrsthtmxkislgcm.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Twilio (SMS OTP) ────────────────────────────────────────
# Get from: console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Resend (Transactional Email) ────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=PETclub <hello@mypetclub.app>

# ── Firebase Admin (FCM Push Notifications) ────────────────
# Get from: console.firebase.google.com → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON contents of the downloaded file here (as a single-line JSON string)
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# ── Razorpay (India Payments — activate after LLC registration) ──
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
