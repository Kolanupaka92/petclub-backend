# ─────────────────────────────────────────────────────────────
#  PETclub Backend — Environment Variables
#  Set all of these in Google Cloud Run → petclub-backend → Variables
#  For local dev: copy to .env and fill in your values
# ─────────────────────────────────────────────────────────────

PORT=5000

# ── URLs ───────────────────────────────────────────────────
# Web app (React SPA) — used in email CTAs, CORS, etc.
FRONTEND_URL=https://app.mypetclub.app
WEB_APP_URL=https://app.mypetclub.app
# Marketing website
WEBSITE_URL=https://mypetclub.app
# Support contact shown in emails and API errors
SUPPORT_EMAIL=support@mypetclub.app

# ── Auth ───────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_64_char_random_secret_here
# Token lifetime — e.g. 30d, 7d, 24h (default: 30d)
JWT_EXPIRES_IN=30d
# Bootstrap admin endpoint secret (POST /api/admin/make-admin)
# Leave unset to disable the endpoint entirely
ADMIN_SECRET=your_admin_bootstrap_secret

# ── Supabase ───────────────────────────────────────────────
# Get from: app.supabase.com → Your Project → Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Firebase Admin (FCM Push Notifications) ────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Paste the entire JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key":"..."}

# ── Resend (Transactional Email) ────────────────────────────
# Get from: resend.com → API Keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=PETclub <hello@mypetclub.app>

# ── Razorpay (India Payments) ──────────────────────────────
# Get from: dashboard.razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# ── Mappls / MapmyIndia (India geocoding) ─────────────────
# Get from: apis.mappls.com → My API Keys
MAPPLS_CLIENT_ID=your_mappls_client_id
MAPPLS_CLIENT_SECRET=your_mappls_client_secret

# ── Revenue split (defaults shown — change without redeploying) ──
# Platform keeps 30%, professional earns 70%
PLATFORM_RATE=0.30
PROVIDER_RATE=0.70
# Razorpay gateway fees
GATEWAY_FEE_PCT_USD=0.029
GATEWAY_FEE_FLAT_USD=0.30
GATEWAY_FEE_PCT_INR=0.02
GATEWAY_FEE_FLAT_INR=0.03

# ── Dispatch / proximity ──────────────────────────────────
# Max km radius to consider a professional "near enough" for dispatch
DISPATCH_RADIUS_KM=70
# Km threshold for "professional is close" push notification
PROXIMITY_ALERT_KM=8

# ── Geocoding contact ─────────────────────────────────────
# Used in Nominatim User-Agent header (OSM requires a contact email/URL)
# Defaults to SUPPORT_EMAIL if not set
NOMINATIM_CONTACT=support@mypetclub.app

# ── Health endpoint ────────────────────────────────────────
# Set this secret so /api/health returns full service info to CI/monitoring
# Unset = public endpoint returns only status + version (no internal config)
HEALTH_SECRET=your_health_secret

# ── Twilio (SMS — optional, stub used if not set) ─────────
# Currently stubbed: SMS logs a warning and no-ops if these are unset
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1xxxxxxxxxx

# ── Sentry (error tracking) ────────────────────────────────
# Get from: sentry.io → New Project → Node.js → DSN
# Leave unset locally — Sentry activates only when this is set
SENTRY_DSN=https://xxxx@oxxxx.ingest.sentry.io/xxxx

# ── Supabase DB password (rate-limit Postgres store) ───────
# Direct Postgres password — NOT the service_role JWT
# Get from: Supabase Dashboard → Settings → Database → Password
SUPABASE_DB_PASSWORD=your_supabase_db_password

# ── Stripe (USA payments — optional, 503s if not set) ──────
# Use sk_test_... keys for the full demo flow; swap to sk_live_ post-LLC
STRIPE_SECRET_KEY=<your-stripe-secret-key>
STRIPE_PUBLISHABLE_KEY=<your-stripe-publishable-key>
STRIPE_WEBHOOK_SECRET=<your-stripe-webhook-secret>

# ── AI Concierge (WhatsApp — optional, static menu if not set) ──
# Get from: console.anthropic.com → API Keys
ANTHROPIC_API_KEY=<your-anthropic-api-key>
# Optional model override (default claude-opus-4-8)
# CONCIERGE_MODEL=claude-opus-4-8
# Public URL Twilio posts to (for signature validation)
# WHATSAPP_WEBHOOK_URL=https://api.mypetclub.app/api/whatsapp/inbound
